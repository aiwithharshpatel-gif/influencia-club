# Server
PORT=5000
NODE_ENV=development
JWT_SECRET=your_super_secure_jwt_secret_min_32_chars_here
JWT_REFRESH_SECRET=your_super_secure_refresh_secret_min_32_chars_here

# Database
DATABASE_URL=mysql://user:password@localhost:3306/influenzia

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Resend SMTP
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_your_resend_api_key
EMAIL_FROM=Influenzia Club <no-reply@influenziaclub.com>

# Razorpay
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Cashfree
CASHFREE_APP_ID=your_app_id
CASHFREE_SECRET_KEY=your_secret_key

# App
FRONTEND_URL=https://influenziaclub.com
REFERRAL_BASE_URL=https://influenziaclub.com/join?ref=
