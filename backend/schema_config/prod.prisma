// Updated for Hostinger Deployment Fix
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Category {
  influencer
  actor
  model
  creator
  public_figure
}

enum CreatorStatus {
  active
  suspended
}

enum InquiryStatus {
  new
  in_progress
  completed
  rejected
}

enum PackageType {
  basic
  growth
  premium
}

enum PointsType {
  earn
  redeem
}

enum PointsReason {
  signup
  referral
  referral_milestone
  admin_grant
  redemption
}

enum ReferralStatus {
  pending
  confirmed
}

enum RewardType {
  featured
  ig_promo
  event_entry
  collab_priority
}

enum RedemptionStatus {
  pending
  approved
  rejected
}

enum CampaignStatus {
  planning
  active
  completed
}

enum CampaignCreatorStatus {
  invited
  confirmed
  completed
}

enum AdminRole {
  super_admin
  manager
}

model Creator {
  id              String        @id @default(uuid()) @db.VarChar(36)
  name            String        @db.VarChar(100)
  email           String        @unique @db.VarChar(150)
  passwordHash    String        @db.VarChar(255)
  mobile          String        @db.VarChar(15)
  instagram       String        @unique @db.VarChar(100)
  category        Category
  city            String        @db.VarChar(50)
  bio             String?       @db.VarChar(200)
  photoUrl        String?       @db.VarChar(500)
  followerCount   String?       @db.VarChar(20)
  isVerified      Boolean       @default(false)
  isFeatured      Boolean       @default(false)
  isApproved      Boolean       @default(false)
  referralCode    String        @unique @db.VarChar(20)
  referredBy      String?       @db.VarChar(36)
  referrer        Creator?      @relation("ReferredCreators", fields: [referredBy], references: [id])
  referrals       Creator[]     @relation("ReferredCreators")
  pointsBalance   Int           @default(0)
  passwordVersion Int           @default(0)
  status          CreatorStatus @default(active)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  pointsTransactions PointsTransaction[]
  referralsMade      Referral[]          @relation("Referrer")
  referralsReceived  Referral[]          @relation("ReferredUser")
  redemptionRequests RedemptionRequest[]
  campaignCreators   CampaignCreator[]
  assignedInquiries  BrandInquiry[]      @relation("AssignedCreator")
  payments           Payment[]
  payouts            Payout[]
  creatorAnalytics   CreatorAnalytics?
  refreshTokens      RefreshToken[]

  @@map("creators")
}

model BrandInquiry {
  id              String        @id @default(uuid()) @db.VarChar(36)
  brandName       String        @db.VarChar(150)
  email           String        @db.VarChar(150)
  mobile          String        @db.VarChar(15)
  budgetRange     String        @db.VarChar(50)
  categories      Json
  message         String        @db.Text
  status          InquiryStatus @default(new)
  assignedTo      String?       @db.VarChar(36)
  assignedCreator Creator?      @relation(fields: [assignedTo], references: [id], name: "AssignedCreator")
  packageType     PackageType?
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  campaigns Campaign[]
  payments  Payment[]

  @@map("brand_inquiries")
}

model PointsTransaction {
  id        String       @id @default(uuid()) @db.VarChar(36)
  creatorId String       @db.VarChar(36)
  creator   Creator      @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  type      PointsType
  reason    PointsReason
  points    Int
  note      String?      @db.VarChar(255)
  createdAt DateTime     @default(now()) @map("created_at")

  @@map("points_transactions")
}

model Referral {
  id             String         @id @default(uuid()) @db.VarChar(36)
  referrerId     String         @db.VarChar(36)
  referrer       Creator        @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredId     String         @db.VarChar(36)
  referredUser   Creator        @relation("ReferredUser", fields: [referredId], references: [id], onDelete: Cascade)
  status         ReferralStatus @default(pending)
  pointsCredited Boolean        @default(false)
  createdAt      DateTime       @default(now()) @map("created_at")

  @@unique([referredId])
  @@map("referrals")
}

model RedemptionRequest {
  id         String           @id @default(uuid()) @db.VarChar(36)
  creatorId  String           @db.VarChar(36)
  creator    Creator          @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  rewardType RewardType
  pointsCost Int
  status     RedemptionStatus @default(pending)
  adminNote  String?          @db.VarChar(255)
  createdAt  DateTime         @default(now()) @map("created_at")

  @@map("redemption_requests")
}

model Campaign {
  id             String         @id @default(uuid()) @db.VarChar(36)
  brandInquiryId String         @db.VarChar(36)
  brandInquiry   BrandInquiry   @relation(fields: [brandInquiryId], references: [id], onDelete: Cascade)
  title          String         @db.VarChar(200)
  status         CampaignStatus @default(planning)
  startDate      DateTime?
  endDate        DateTime?
  notes          String?        @db.Text
  createdAt      DateTime       @default(now()) @map("created_at")

  campaignCreators CampaignCreator[]
  analytics        CampaignAnalytics?
  review           Review?

  @@map("campaigns")
}

model CampaignCreator {
  id           String                @id @default(uuid()) @db.VarChar(36)
  campaignId   String                @db.VarChar(36)
  campaign     Campaign              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creatorId    String                @db.VarChar(36)
  creator      Creator               @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  status       CampaignCreatorStatus @default(invited)
  deliverables String?               @db.Text
  createdAt    DateTime              @default(now()) @map("created_at")

  @@unique([campaignId, creatorId])
  @@map("campaign_creators")
}

model Admin {
  id              String    @id @default(uuid()) @db.VarChar(36)
  name            String    @db.VarChar(100)
  email           String    @unique @db.VarChar(150)
  passwordHash    String    @db.VarChar(255)
  passwordVersion Int       @default(0)
  role            AdminRole @default(manager)
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("admins")
}

model Payment {
  id                String        @id @default(uuid()) @db.VarChar(36)
  brandInquiryId    String        @db.VarChar(36)
  brandInquiry      BrandInquiry  @relation(fields: [brandInquiryId], references: [id], onDelete: Cascade)
  creatorId         String        @db.VarChar(36)
  creator           Creator       @relation(fields: [creatorId], references: [id])
  amount            Decimal       @db.Decimal(10, 2)
  platformFee       Decimal       @db.Decimal(10, 2)
  creatorEarnings   Decimal       @db.Decimal(10, 2)
  status            PaymentStatus @default(pending)
  paymentMethod     String?       @db.VarChar(50)
  razorpayOrderId   String?       @unique @db.VarChar(100)
  razorpayPaymentId String?       @unique @db.VarChar(100)
  razorpaySignature String?       @db.VarChar(255)
  gstAmount         Decimal       @default(0) @db.Decimal(10, 2)
  tdsAmount         Decimal       @default(0) @db.Decimal(10, 2)
  invoiceUrl        String?       @db.LongText
  agreementUrl      String?       @db.LongText
  paidAt            DateTime?
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  @@map("payments")
}

model Payout {
  id               String       @id @default(uuid()) @db.VarChar(36)
  creatorId        String       @db.VarChar(36)
  creator          Creator      @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  amount           Decimal      @db.Decimal(10, 2)
  status           PayoutStatus @default(pending)
  paymentMethod    String       @db.VarChar(50) // UPI, Bank Transfer, etc.
  upiId            String?      @db.VarChar(100)
  accountNumber    String?      @db.VarChar(50)
  ifscCode         String?      @db.VarChar(20)
  bankName         String?      @db.VarChar(100)
  accountHolder    String?      @db.VarChar(100)
  cashfreePayoutId String?      @db.VarChar(100)
  processedAt      DateTime?
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  @@map("payouts")
}

model CampaignAnalytics {
  id               String   @id @default(uuid()) @db.VarChar(36)
  campaignId       String   @unique @db.VarChar(36)
  campaign         Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  totalReach       Int      @default(0)
  totalImpressions Int      @default(0)
  totalEngagement  Int      @default(0)
  totalClicks      Int      @default(0)
  engagementRate   Decimal  @default(0) @db.Decimal(5, 2)
  ctr              Decimal  @default(0) @db.Decimal(5, 2)
  conversions      Int      @default(0)
  roi              Decimal  @default(0) @db.Decimal(5, 2)
  reportUrl        String?  @db.VarChar(500)
  lastUpdated      DateTime @updatedAt @map("updated_at")
  createdAt        DateTime @default(now()) @map("created_at")

  @@map("campaign_analytics")
}

model CreatorAnalytics {
  id                  String   @id @default(uuid()) @db.VarChar(36)
  creatorId           String   @unique @db.VarChar(36)
  creator             Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  profileViews        Int      @default(0)
  totalEarnings       Decimal  @default(0) @db.Decimal(10, 2)
  avgEngagementRate   Decimal  @default(0) @db.Decimal(5, 2)
  totalCollaborations Int      @default(0)
  successRate         Decimal  @default(0) @db.Decimal(5, 2)
  responseTime        Int      @default(0) // in hours
  lastUpdated         DateTime @updatedAt @map("updated_at")
  createdAt           DateTime @default(now()) @map("created_at")

  @@map("creator_analytics")
}

model Message {
  id            String   @id @default(uuid()) @db.VarChar(36)
  senderId      String   @db.VarChar(36)
  senderType    String   @db.VarChar(20) // 'creator' or 'brand'
  recipientId   String   @db.VarChar(36)
  recipientType String   @db.VarChar(20)
  campaignId    String?  @db.VarChar(36)
  content       String   @db.Text
  attachments   Json?
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("messages")
}

model Review {
  id             String   @id @default(uuid()) @db.VarChar(36)
  campaignId     String   @unique @db.VarChar(36)
  campaign       Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  brandRating    Int // 1-5
  creatorRating  Int // 1-5
  brandReview    String?  @db.Text
  creatorReview  String?  @db.Text
  wouldWorkAgain Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("reviews")
}

enum PaymentStatus {
  pending
  initiated
  processing
  completed
  failed
  refunded
  disputed
}

enum PayoutStatus {
  pending
  processing
  completed
  failed
  on_hold
}

model OtpVerification {
  id        String   @id @default(uuid()) @db.VarChar(36)
  email     String   @db.VarChar(150)
  otp       String   @db.VarChar(255)
  userData  Json
  expiresAt DateTime
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email, otp])
  @@map("otp_verifications")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.VarChar(36)
  creatorId String   @db.VarChar(36)
  creator   Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  tokenHash String   @unique @db.VarChar(64)
  expiresAt DateTime
  createdAt DateTime @default(now()) @map("created_at")

  @@index([creatorId, expiresAt])
  @@map("refresh_tokens")
}
