{
  "name": "influenzia-backend",
  "version": "1.0.0",
  "description": "Influenzia Club Backend API",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "build": "echo 'Backend build complete'",
    "test": "node --test",
    "admin:create": "node scripts/create-admin.js",
    "prisma:generate": "prisma generate --schema=./schema_config/prod.prisma",
    "prisma:migrate": "prisma migrate dev --schema=./schema_config/prod.prisma",
    "prisma:deploy": "prisma migrate deploy --schema=./schema_config/prod.prisma",
    "prisma:studio": "prisma studio --schema=./schema_config/prod.prisma"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.5",
    "validator": "^13.15.35",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma": "^5.10.0"
  }
}
