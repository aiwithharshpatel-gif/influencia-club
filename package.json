{
  "name": "influenzia-club",
  "version": "1.0.0",
  "description": "India's Next-Gen Influencer Platform",
  "private": true,
  "type": "module",
  "main": "unified-startup.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm install && npm run build && node ../copy-dist.js",
    "build:backend": "cd backend && npm install && npx prisma generate",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "postinstall": "npm run build",
    "start": "node unified-startup.js"
  },
  "dependencies": {
    "vite": "^5.1.6",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "axios": "^1.6.7",
    "react-hook-form": "^7.51.0",
    "lucide-react": "^0.344.0",
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.0.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.12",
    "uuid": "^9.0.1",
    "validator": "^13.11.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prisma": "^5.10.0"
  }
}
