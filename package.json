{
  "name": "influenzia-club",
  "version": "1.0.0",
  "description": "India's Next-Gen Influencer Platform",
  "private": true,
  "main": "backend/src/app.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "install:all": "npm ci && cd backend && npm ci && cd ../frontend && npm ci",
    "check": "npm run prisma:validate && cd backend && npm test && cd ../frontend && npm run build",
    "start": "cd backend && npm start",
    "prisma:generate": "cd backend && npx prisma generate --schema=./schema_config/prod.prisma",
    "prisma:validate": "cd backend && npx prisma validate --schema=./schema_config/prod.prisma"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "playwright": "^1.60.0"
  }
}
