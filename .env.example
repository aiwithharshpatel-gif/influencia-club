# MySQL container
MYSQL_DATABASE=influenzia
MYSQL_USER=influenzia_app
MYSQL_PASSWORD=replace_with_a_long_random_password
MYSQL_ROOT_PASSWORD=replace_with_a_different_long_random_password
DATABASE_URL=mysql://influenzia_app:replace_with_a_long_random_password@database:3306/influenzia

# Application
PORT=5000
FRONTEND_URL=https://influenziaclub.com,https://www.influenziaclub.com
REFERRAL_BASE_URL=https://influenziaclub.com/join?ref=
VITE_API_URL=/api

# Generate independent random values of at least 32 characters
JWT_SECRET=replace_with_a_random_64_character_secret
JWT_REFRESH_SECRET=replace_with_a_different_random_64_character_secret
JWT_ADMIN_SECRET=replace_with_a_third_random_64_character_secret
OTP_SECRET=replace_with_a_fourth_random_64_character_secret

# Hostinger Email SMTP
# Confirm the exact hostname in Hostinger hPanel for your mailbox.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@influenziaclub.com
SMTP_PASS=replace_with_the_mailbox_password
EMAIL_FROM=Influenzia Club <no-reply@influenziaclub.com>
EMAIL_REPLY_TO=hello@influenziaclub.com
SUPPORT_EMAIL=hello@influenziaclub.com

# Optional services
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Keep disabled until the complete business payment flow has been tested.
PAYMENTS_ENABLED=false
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
PAYOUTS_ENABLED=false
